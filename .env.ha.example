# Copy to `.env.ha` in the repo root (gitignored). Used by deploy tasks / scripts.
# Lines are KEY=value. Use # for comments.

# Optional: private key path if not ~/.ssh/ha_deploy (deploy scripts).
# HA_SSH_IDENTITY=C:/Users/You/.ssh/ha_deploy

HA_HOST=192.168.116.55
# HA_USER defaults to root when unset (same as deploy-ha-rsync.sh / KVent).
HA_USER=root

# Optional: after deploy, restart HA Core via REST API (Settings -> System -> Restart)
# HA_HTTP_URL=http://192.168.116.55:8123
# HA_TOKEN=your_long_lived_access_token
